NODE_ENV=development
PORT=3000
FRONTEND_ORIGINS=http://localhost:3001,http://localhost:3000
API_RATE_LIMIT_LIMIT=120
API_RATE_LIMIT_TTL_SECONDS=60
API_RATE_LIMIT_BLOCK_SECONDS=60
API_AUTH_RATE_LIMIT_LIMIT=10
API_AUTH_RATE_LIMIT_TTL_SECONDS=60
API_AUTH_RATE_LIMIT_BLOCK_SECONDS=300
API_CACHE_ROLES_TTL_SECONDS=60

# Optional full Postgres URL for managed providers like Neon.
# Used only when NODE_ENV is staging or production.
DATABASE_URL=
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=
DB_ENABLE_CHANNEL_BINDING=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=school_management
DB_SYNC=true
DB_LOGGING=false

# Optional managed Redis URL for providers like Upstash.
# Used only when NODE_ENV is staging or production.
# Prefer rediss:// for TLS-enabled providers.
REDIS_URL=
REDIS_TLS=
REDIS_TLS_REJECT_UNAUTHORIZED=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

ACCESS_TOKEN_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
ACCESS_COOKIE_NAME=sms_access_token
REFRESH_COOKIE_NAME=sms_refresh_token
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=Admin@12345

SERVICE_NAME=school-management-system
LOG_LEVEL=debug
LOG_REDIS_OPERATIONS=false
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USERNAME=
GRAFANA_LOKI_PASSWORD=
GRAFANA_LOKI_BATCH_SIZE=50
GRAFANA_LOKI_FLUSH_INTERVAL_MS=5000
GRAFANA_LOKI_RETRY_BACKOFF_MS=5000
GRAFANA_LOKI_TIMEOUT_MS=5000
GRAFANA_LOKI_MAX_QUEUE_SIZE=1000

METRICS_DEFAULT_METRICS_ENABLED=true
METRICS_DB_PING_INTERVAL_MS=30000
METRICS_REDIS_PING_INTERVAL_MS=30000
METRICS_SLOW_DB_QUERY_THRESHOLD_MS=500

LOKI_DOCKER_VERSION=3.6.0
PROMTAIL_DOCKER_VERSION=3.6.0
PROMETHEUS_DOCKER_VERSION=v3.10.0
GRAFANA_DOCKER_VERSION=12.4.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
